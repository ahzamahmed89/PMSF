{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "stop:node",
			"type": "shell",
			"command": "powershell -NoProfile -Command \"Get-Process -Name node -ErrorAction SilentlyContinue | Stop-Process -Force\"",
			"problemMatcher": []
		},
		{
			"label": "start:backend",
			"type": "shell",
			"command": "npm run server",
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "start:frontend",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "restart:front+back",
			"dependsOn": [
				"stop:node",
				"start:backend",
				"start:frontend"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		}
	]
}